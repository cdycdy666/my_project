# Optional LLM override. If omitted, scripts can read model config from ~/.openclaw/openclaw.json.
LLM_API_KEY=
LLM_BASE_URL=https://oneapi-comate.baidu-int.com/v1
LLM_MODEL=gpt-5.4

# Optional InfoFlow override. If omitted, scripts can read app config from ~/.openclaw/openclaw.json.
INFOFLOW_APP_KEY=
INFOFLOW_APP_SECRET=
