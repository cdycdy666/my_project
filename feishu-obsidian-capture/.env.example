FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: fill these only if Feishu event logs show token/encryption errors.
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Obsidian vault path
OBSIDIAN_VAULT_DIR=/Users/chendingyu/my_project/personal-kb

# Daily reminder time in Asia/Shanghai, 24-hour format
DAILY_MORNING_TIME=07:30
DAILY_REMINDER_TIME=21:30

# Daily AI summary time in Asia/Shanghai, 24-hour format
DAILY_SUMMARY_TIME=23:00

# OpenAI-compatible LLM provider for daily summary
LLM_API_KEY=sk-...
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
