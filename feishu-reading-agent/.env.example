# This project reads /Users/chendingyu/my_project/.env.
# Keep real secrets in the root .env, not in this file.

# Feishu app for the new reading agent.
# Do not reuse the Obsidian Capture app unless you intentionally want one bot.
READING_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
READING_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
READING_FEISHU_VERIFICATION_TOKEN=
READING_FEISHU_ENCRYPT_KEY=

# Personal situation knowledge base, read-only in the first version.
READING_PERSONAL_KB_DIR=/Users/chendingyu/my_project/personal-kb

# Tencent WeChatReading Agent Gateway.
WEREAD_API_KEY=wrk-...

# Optional: override the shared LLM config for this reading agent.
READING_LLM_API_KEY=sk-...
READING_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
READING_LLM_MODEL=qwen-plus

# Interaction trace logs. Enabled by default.
READING_TRACE_LOG_ENABLED=true
READING_TRACE_LOG_DIR=/Users/chendingyu/my_project/feishu-reading-agent/logs/traces

# Personal memory Researcher: BM25 + embedding + Page-ID/record-ID source readback.
MEMORY_RESEARCH_ENABLED=true
MEMORY_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MEMORY_EMBEDDING_MODEL=text-embedding-v4
MEMORY_EMBEDDING_DIMENSIONS=1024
MEMORY_RESEARCH_MAX_ROUNDS=2
MEMORY_RESEARCH_CACHE_DIR=/Users/chendingyu/my_project/feishu-reading-agent/data/memory-researcher
