TRANSCRIPTION_PROVIDER=local_whisper

QIANFAN_MCP_URL=https://qianfan.baidubce.com/v2/tools/media-insight/mcp
QIANFAN_BEARER_TOKEN=your_bearer_token

# Optional: set these if tool autodiscovery is not enough.
QIANFAN_CREATE_TOOL=
QIANFAN_STATUS_TOOL=
QIANFAN_RESULT_TOOL=
QIANFAN_DISABLE_PROXY=true

# Optional: override MCP protocol version if the remote server negotiates differently.
QIANFAN_MCP_PROTOCOL_VERSION=2025-06-18

DOUBAO_MIAOJI_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/lark/submit
DOUBAO_MIAOJI_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/lark/query
DOUBAO_MIAOJI_API_KEY=
DOUBAO_MIAOJI_APP_KEY=
DOUBAO_MIAOJI_ACCESS_KEY=
DOUBAO_MIAOJI_RESOURCE_ID=volc.lark.minutes
DOUBAO_MIAOJI_DISABLE_PROXY=true
DOUBAO_MIAOJI_POLL_INTERVAL_SECONDS=15
DOUBAO_MIAOJI_TIMEOUT_SECONDS=900
DOUBAO_MIAOJI_FILE_TYPE=audio
DOUBAO_MIAOJI_SOURCE_LANG=zh_cn
DOUBAO_MIAOJI_ALL_ACTIVATE=false
DOUBAO_MIAOJI_AUDIO_TRANSCRIPTION_ENABLE=true
DOUBAO_MIAOJI_SPEAKER_IDENTIFICATION=true
DOUBAO_MIAOJI_NUMBER_OF_SPEAKER=0
DOUBAO_MIAOJI_HOT_WORDS=
DOUBAO_MIAOJI_TRANSLATION_ENABLE=false
DOUBAO_MIAOJI_TARGET_LANG=zh_cn
DOUBAO_MIAOJI_INFORMATION_EXTRACTION_ENABLE=true
DOUBAO_MIAOJI_INFORMATION_EXTRACTION_TYPES=question_answer
DOUBAO_MIAOJI_SUMMARIZATION_ENABLE=true
DOUBAO_MIAOJI_SUMMARIZATION_TYPES=summary
DOUBAO_MIAOJI_CHAPTER_ENABLE=true

# Polling behavior
PIPELINE_POLL_INTERVAL_SECONDS=15
PIPELINE_TIMEOUT_SECONDS=900

# Optional: store raw JSON result locally for debugging.
PIPELINE_OUTPUT_DIR=./output

LOCAL_WHISPER_MODEL=small
LOCAL_WHISPER_DEVICE=auto
LOCAL_WHISPER_COMPUTE_TYPE=auto
LOCAL_WHISPER_LANGUAGE=zh
LOCAL_WHISPER_BEAM_SIZE=5
LOCAL_WHISPER_VAD_FILTER=true

BOS_ACCESS_KEY_ID=
BOS_SECRET_ACCESS_KEY=
BOS_BUCKET=
BOS_ENDPOINT=bj.bcebos.com
BOS_OBJECT_PREFIX=interview-audio
BOS_SIGNED_URL_EXPIRES=86400
BOS_MULTIPART_THRESHOLD_MB=8
BOS_MULTIPART_CHUNK_MB=5
BOS_DISABLE_PROXY=true

NOTION_TOKEN=secret_xxx
NOTION_DATABASE_ID=your_database_id
NOTION_VERSION=2022-06-28

# Map your Notion property names here.
NOTION_PROP_CANDIDATE=候选人
NOTION_PROP_ROLE=岗位
NOTION_PROP_DATE=面试日期
NOTION_PROP_ROUND=轮次
NOTION_PROP_STATUS=处理状态
NOTION_PROP_AUDIO_URL=录音链接
NOTION_PROP_TRANSCRIPT_URL=转写链接
NOTION_PROP_DECISION=结论
NOTION_PROP_TAGS=标签
NOTION_PROP_SUMMARY=摘要

# Optional defaults
DEFAULT_STATUS_DONE=完成
DEFAULT_TAGS=
